generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id           String   @id @default(cuid())
  title        String
  templateId   String?  @default("default")
  content      Json
  version      Int      @default(1)
  penpotFileId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
